{
  "entities": {
    "ShopOwner": {
      "title": "Shop Owner",
      "description": "Represents a whitelisted shop owner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "totalDiscountsCount": { "type": "number", "description": "Count of redemptions at this shop" },
        "totalDiscountsValue": { "type": "number", "description": "Cumulative discount percentage or value given" }
      },
      "required": ["name", "email"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A redemption code generated by a user.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "userUsn": { "type": "string", "description": "Full USN of the user" },
        "discountPercentage": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "used"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "usedAt": { "type": "string", "format": "date-time" },
        "redeemedByShopId": { "type": "string" }
      },
      "required": ["code", "userUsn", "discountPercentage", "status"]
    },
    "RedemptionLog": {
      "title": "Redemption Log",
      "description": "Log of a successful coupon redemption.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "couponCode": { "type": "string" },
        "userUsnMasked": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "shop_owners/{ownerId}": {
      "schema": "ShopOwner",
      "description": "Whitelisted shop owners."
    },
    "coupons/{couponCode}": {
      "schema": "Coupon",
      "description": "Available redemption codes."
    },
    "shop_owners/{ownerId}/redemptions": {
      "schema": "RedemptionLog",
      "description": "History of redemptions for a specific shop."
    }
  }
}
